# 项目基础设置
ENV=development
LOG_LEVEL=debug

# 数据库配置
SQL_ALCHEMY_DATABASE_URI=postgresql+asyncpg://postgres:postgres@localhost:5432/manus

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 腾讯云相关配置
TENCENT_CLOUD_SECRET_ID=your-secret-id
TENCENT_CLOUD_SECRET_KEY=your-secret-key
TENCENT_CLOUD_REGION=ap-shanghai
TENCENT_CLOUD_BUCKET_NAME=your-bucket-name
COS_SCHEME=https
